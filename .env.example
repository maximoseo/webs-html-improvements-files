# Copy to .env.local and fill in real values. .env.local is gitignored.
# Keep only providers/models that are supported by server.py and verified in OpenRouter catalog.

# --- Dashboard auth ---
DASHBOARD_JWT_SECRET=*** openssl rand -hex 32
DASHBOARD_AUTH_SECRET=*** openssl rand -hex 32
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=*** break-glass password

# --- Supabase (dashboard storage / comments / optional reports) ---
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_MANAGEMENT_TOKEN=*** only needed for seed/migration scripts
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_DB_PASSWORD=*** direct Postgres access, optional

# --- Main LLM route (recommended) ---
# Verified working via this dashboard/OpenRouter smoke:
# openai/gpt-5.4
# anthropic/claude-opus-4.7
# google/gemini-3.1-pro-preview
# moonshotai/kimi-k2.6
# z-ai/glm-4.6
OPENROUTER_API_KEY=***
OPENROUTER_SITE_URL=https://html-redesign-dashboard.maximo-seo.ai/
OPENROUTER_APP_NAME=HTML Redesign Dashboard

# --- Optional direct provider fallbacks supported by server.py ---
OPENAI_API_KEY=***
ANTHROPIC_API_KEY=***
GEMINI_API_KEY=***
KIMI_API_KEY=***
XAI_API_KEY=***
MINIMAX_API_KEY=***
GLM_API_KEY=***

# --- Working model overrides only ---
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-opus-4.6
GEMINI_MODEL=gemini-3.1-pro-preview
KIMI_MODEL=kimi-k2.6
XAI_MODEL=grok-4.20
MINIMAX_MODEL=minimax-m2.7
GLM_MODEL=glm-4.6

# --- n8n / GitHub ---
N8N_BASE_URL=https://websiseo.app.n8n.cloud
N8N_API_KEY=*** read-only n8n API key
N8N_KWR_WEBHOOK_URL=*** approve/deploy webhook only
GITHUB_TOKEN=***

# --- Tests ---
TEST_ADMIN_EMAIL=service@maximo-seo.com
TEST_ADMIN_PASSWORD=***
