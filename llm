#!/usr/bin/env python3
"""
llm - Simple CLI to chat with any configured LLM provider.

Usage:
  llm "your prompt"                          # use default provider
  llm -p openrouter:claude-sonnet-4-6 "..."  # use a specific provider
  llm --use openrouter:claude-sonnet-4-6     # set default provider
  llm --current                              # show current default
  llm --list                                 # list all providers + status
  llm --interactive                          # start a chat session
"""

import os
import sys
import json
import time
from pathlib import Path

# ── Config ────────────────────────────────────────────────────────────────────
CONFIG_FILE = Path.home() / ".hermes" / "llm_config.json"
ENV_FILE    = Path.home() / ".hermes" / ".env"

DEFAULT_CONFIG = {
    "default_provider": "openrouter:claude-sonnet-4-6",
    "max_tokens": 1024,
    "temperature": 0.7,
}

def load_config() -> dict:
    if CONFIG_FILE.exists():
        return {**DEFAULT_CONFIG, **json.loads(CONFIG_FILE.read_text())}
    return DEFAULT_CONFIG.copy()

def save_config(cfg: dict):
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2))

def load_env(path: Path) -> dict:
    env = {}
    if not path.exists():
        return env
    for line in path.read_text().splitlines():
        line = line.strip()
        if line and not line.startswith("#") and "=" in line:
            k, _, v = line.partition("=")
            env[k.strip()] = v.strip()
    return env

_env = load_env(ENV_FILE)

def get(key: str, default: str = "") -> str:
    return os.environ.get(key) or _env.get(key, default)

