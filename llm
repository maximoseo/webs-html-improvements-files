# ── Backend calls ─────────────────────────────────────────────────────────────
def call_openai(model, base_url, api_key, messages, max_tokens, temperature):
    from openai import OpenAI
    client = OpenAI(base_url=base_url, api_key=api_key or "no-key")
    resp = client.chat.completions.create(
        model=model, messages=messages,
        max_tokens=max_tokens, temperature=temperature,
    )
    return resp.choices[0].message.content or ""

def call_anthropic(model, api_key, messages, max_tokens, temperature):
    import anthropic
    client = anthropic.Anthropic(api_key=api_key)
    # Convert system message if present
    system = ""
    user_msgs = []
    for m in messages:
        if m["role"] == "system":
            system = m["content"]
        else:
            user_msgs.append(m)
    kwargs = dict(model=model, max_tokens=max_tokens,
                  messages=user_msgs)
    if system:
        kwargs["system"] = system
    resp = client.messages.create(**kwargs)
    return resp.content[0].text

def chat(provider_key: str, messages: list, cfg: dict) -> str:
    if provider_key not in PROVIDERS:
        raise ValueError(f"Unknown provider '{provider_key}'. Run: llm --list")

    label, backend, model, base_url, api_key = PROVIDERS[provider_key]

    if backend == "anthropic":
        return call_anthropic(model, api_key, messages,
                              cfg["max_tokens"], cfg["temperature"])
    else:
        return call_openai(model, base_url, api_key, messages,
                           cfg["max_tokens"], cfg["temperature"])

# ── Display helpers ───────────────────────────────────────────────────────────
def has_key(provider_key: str) -> bool:
    _, _, _, _, api_key = PROVIDERS[provider_key]
    return bool(api_key and api_key.strip())

def list_providers(cfg: dict):
    default = cfg["default_provider"]
    print(f"\n{'KEY':<38} {'STATUS':<10} LABEL")
    print("─" * 75)
    for key, (label, *rest) in PROVIDERS.items():
        status = "✓ ready" if has_key(key) else "✗ no key"
        marker = " ◄ default" if key == default else ""
        print(f"  {key:<36} {status:<10} {label}{marker}")
    print(f"\nSet API keys in: {ENV_FILE}\n")

# ── Interactive chat ──────────────────────────────────────────────────────────
def interactive(provider_key: str, cfg: dict):
    label = PROVIDERS[provider_key][0]
    print(f"\n💬  Chat with {label}")
    print(f"    Type 'exit' or Ctrl+C to quit, 'switch <key>' to change provider.\n")

    messages = []
    while True:
        try:
            user_input = input("You: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nBye!")
            break

        if not user_input:
            continue
        if user_input.lower() in ("exit", "quit", "q"):
            print("Bye!")
            break
        if user_input.lower().startswith("switch "):
            new_key = user_input.split(None, 1)[1].strip()
            if new_key in PROVIDERS:
                provider_key = new_key
                label = PROVIDERS[provider_key][0]
                print(f"  ⇄  Switched to {label}\n")
            else:
                print(f"  ✗  Unknown provider. Run: llm --list\n")
            continue

        messages.append({"role": "user", "content": user_input})
        try:
            start = time.time()
            reply = chat(provider_key, messages, cfg)
            elapsed = time.time() - start
            messages.append({"role": "assistant", "content": reply})
            print(f"\nAssistant ({elapsed:.1f}s): {reply}\n")
        except Exception as e:
            print(f"  ✗  Error: {e}\n")
            messages.pop()  # remove failed user message

# ── Main ──────────────────────────────────────────────────────────────────────
def main():
    cfg = load_config()
    args = sys.argv[1:]

    # ── llm --list
    if not args or args[0] == "--list":
        list_providers(cfg)
        return

    # ── llm --current
    if args[0] == "--current":
        key = cfg["default_provider"]
        label = PROVIDERS.get(key, ("unknown",))[0]
        status = "✓ ready" if has_key(key) else "✗ no API key"
        print(f"Default provider: {key}  ({label})  [{status}]")
        return

    # ── llm --use <provider>
    if args[0] in ("--use", "--switch", "--set"):
        if len(args) < 2:
            print("Usage: llm --use <provider-key>")
            return
        new_key = args[1]
        if new_key not in PROVIDERS:
            print(f"Unknown provider '{new_key}'")
            list_providers(cfg)
            return
        cfg["default_provider"] = new_key
        save_config(cfg)
        label = PROVIDERS[new_key][0]
        print(f"Default set to: {new_key}  ({label})")
        return

    # ── llm --interactive / --chat
    if args[0] in ("--interactive", "--chat", "-i"):
        provider_key = args[1] if len(args) > 1 else cfg["default_provider"]
        interactive(provider_key, cfg)
        return

    # ── Parse -p / --provider flag
    provider_key = cfg["default_provider"]
    prompt_args  = args

    if args[0] in ("-p", "--provider") and len(args) >= 2:
        provider_key = args[1]
        prompt_args  = args[2:]
    elif args[0].startswith("--provider="):
        provider_key = args[0].split("=", 1)[1]
        prompt_args  = args[1:]

    if not prompt_args:
        print(__doc__)
        return

    prompt = " ".join(prompt_args)

    if provider_key not in PROVIDERS:
        print(f"Unknown provider '{provider_key}'. Run: llm --list")
        sys.exit(1)

    label = PROVIDERS[provider_key][0]
    print(f"[{label}]")

    try:
        start  = time.time()
        reply  = chat(provider_key, [{"role": "user", "content": prompt}], cfg)
        elapsed = time.time() - start
        print(reply)
        print(f"\n({elapsed:.2f}s)", file=sys.stderr)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
